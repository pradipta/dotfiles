function gswitch () {
    if [ -z "$1" ]
    then
        local branch_name
        branch_name=$(__fuzzySelectGitBranch)
        if [ -n "$branch_name" ]
        then
            git checkout "$branch_name"
        fi
    else
        local branch_name=$1 
        git checkout "$branch_name"
    fi
}

