desk() {
    # key -> "host|emoji|label". `order` keeps the menu in a stable sequence
    # (zsh assoc arrays are unordered).
    local -A desks=(
        go   "pradiptas-go.devpod-ind|🚀|Go (Standard)"
        one  "pradiptas-one.devpod-ind|🐍|One (Python)"
        java "pradiptas-java.devpod-ind|☕|Java"
        web  "pradiptas-web.devpod-ind|🌐|Web"
    )
    local order=(go one java web)

    # Map friendly synonyms onto canonical keys.
    local target=$1
    case "$target" in
        standard) target=go  ;;
        python)   target=one ;;
    esac

    local key=""
    if [[ -n "$target" ]]; then
        if [[ -n "${desks[$target]}" ]]; then
            key=$target
        else
            echo "⚠️ Unknown environment: $target. Opening menu..."
        fi
    fi

    # No (valid) arg → interactive picker showing just the labels.
    if [[ -z "$key" ]]; then
        local choice
        choice=$(for k in $order; do printf '%s\t%s\n' "$k" "${desks[$k]##*|}"; done \
            | fzf --height 20% --reverse --border --header="Select Environment:" \
                  --delimiter='\t' --with-nth=2)
        [[ -z "$choice" ]] && { echo "Selection cancelled."; return 1; }
        key=${choice%%$'\t'*}
    fi

    local entry=${desks[$key]}
    local host=${entry%%|*}
    local emoji=${${entry#*|}%%|*}
    local label=${entry##*|}
    echo "$emoji SSHing into $label environment..."
    ssh "$host"
}

alias claude="claude --model 'claude-opus-4-8[1m]'"
alias cc=claude
alias cc-skip-perm="claude --dangerously-skip-permissions"
alias codex="aifx agent run codex"
alias codex-app="aifx agent run codex app"
alias cx=codex
alias cx-app=codex-app
alias oc="aifx agent run opencode"

# ARH Stuff
alias aco="arh checkout"
alias acn="arh checkout next"
alias acp="arh checkout prev"
alias acf="arh checkout first"
alias acl="arh checkout last"
alias arhl="arh lint"
alias arhp="arh publish"