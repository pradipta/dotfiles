desk() {
    local target=$1

    # 1. Handle direct arguments
    if [ -n "$target" ]; then
        case "$target" in
            "go"|"standard")
                echo "🚀 SSHing into Go environment..."
                ssh pradiptas-go.devpod-ind
                return
                ;;
            "one"|"python")
                echo "☕ SSHing into Python (One) environment..."
                ssh pradiptas-one.devpod-ind
                return
                ;;
            "java")
                echo "☕ SSHing into Java environment..."
                ssh pradiptas-java.devpod-ind
                return
                ;;
            "web")
                echo "🌐 SSHing into Web environment..."
                ssh pradiptas-web.devpod-ind
                return
                ;;
            *)
                echo "⚠️ Unknown environment: $target. Opening menu..."
                ;;
        esac
    fi

    # 2. Interactive Selection
    local env_list="Go (Standard)\nOne (Python)\nJava\nWeb"
    local choice=$(echo -e "$env_list" | fzf --height 10% --reverse --border --header="Select Environment:")

    case "$choice" in
        "Go (Standard)")
            echo "🚀 SSHing into Go environment..."
            ssh pradiptas-go.devpod-ind
            ;;
        "Java")
            echo "☕ SSHing into Java environment..."
            ssh pradiptas-java.devpod-ind
            ;;
        "One")
            echo "☕ SSHing into Python environment..."
            ssh pradiptas-one.devpod-ind
            ;;
        "Web")
            echo "🌐 SSHing into Web environment..."
            ssh pradiptas-web.devpod-ind
            ;;
        *)
            echo "Selection cancelled."
            ;;
    esac
}

alias claude="claude --model 'claude-opus-4-8[1m]'"
alias cc=claude
alias cc-skip-perm="claude --dangerously-skip-permissions"
alias codex="aifx agent run codex"
alias codex-app="aifx agent run codex app"
alias cx=codex
alias cx-app=codex-app
alias oc="aifx agent run opencode"

# ARH Stuff
alias aco="arh checkout"
alias acn="arh checkout next"
alias acp="arh checkout prev"
alias acf="arh checkout first"
alias acl="arh checkout last"
alias arhl="arh lint"
alias arhp="arh publish"